{
  "manifest_version": 3,
  "name": "Draft Helper",
  "version": "1.0.0",
  "description": "Overlay for DraftKings Bestball draft: roster tracker, stacking targets, draft capital chart, and opponent schedule.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.draftkings.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.draftkings.com/*draft*"],
      "js": ["assets/content.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["https://www.draftkings.com/*"]
    }
  ]
}
